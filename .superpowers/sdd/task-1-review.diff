-/* Fix baris bawah grafik supaya 3 kolom */
-.grafik-grid {
-  grid-template-columns: 1fr 1fr 1fr;
-}
-
-.chart-box-wide {
-  grid-column: 1 / 3;
-}
-
-.grafik-grid > .chart-box:nth-child(2) {
-  grid-column: 3;
-  grid-row: 1;
-}
-
-.grafik-grid > .chart-box:nth-child(3) { grid-column: 1; grid-row: 2; }
-.grafik-grid > .chart-box:nth-child(4) { grid-column: 2; grid-row: 2; }
